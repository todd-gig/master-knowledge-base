{
  "version": "3.0",
  "decision_modes": [
    "Python-First",
    "Claude-First",
    "Hybrid"
  ],
  "architectures": [
    "Pure Python",
    "Pure Claude",
    "Claude parse -> Python decide",
    "Claude decide -> Python execute",
    "Claude supervise -> Python run",
    "Claude parse -> Python score -> Claude review exceptions"
  ],
  "thresholds": {
    "dominance_margin_pct": 15,
    "hybrid_within_top_pct": 10,
    "high_confidence_min": 0.9,
    "moderate_confidence_min": 0.75,
    "low_confidence_min": 0.6
  },
  "overrides": {
    "massive_volume_and_stable_rules": "avoid_pure_claude",
    "high_compliance_and_low_explainability": "require_review",
    "irreversible_action_and_low_confidence": "escalate_human"
  }
}

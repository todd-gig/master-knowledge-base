{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decision Payload",
  "type": "object",
  "required": [
    "decision_type",
    "normalized_variables",
    "routing_classification",
    "recommended_architecture",
    "confidence_score",
    "exception_flags",
    "recommended_action",
    "review_required"
  ],
  "properties": {
    "decision_type": {
      "type": "string"
    },
    "normalized_variables": {
      "type": "object"
    },
    "routing_classification": {
      "enum": [
        "Python-First",
        "Claude-First",
        "Hybrid"
      ]
    },
    "recommended_architecture": {
      "type": "string"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "exception_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_action": {
      "type": "string"
    },
    "review_required": {
      "type": "boolean"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}

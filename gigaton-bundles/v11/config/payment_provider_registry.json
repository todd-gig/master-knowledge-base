{
  "default_provider": "stripe",
  "providers": {
    "stripe": {
      "enabled": true,
      "supports_checkout_sessions": true,
      "supports_payment_intents": true,
      "supports_webhooks": true
    },
    "godaddy_poynt": {
      "enabled": true,
      "supports_checkout_sessions": false,
      "supports_payment_intents": false,
      "supports_orders_transactions": true,
      "supports_webhooks": "implementation_specific"
    }
  },
  "routing_rules": {
    "online_checkout": "stripe",
    "in_person_or_poynt_connected": "godaddy_poynt"
  }
}
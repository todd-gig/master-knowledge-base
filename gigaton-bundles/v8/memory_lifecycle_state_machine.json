{
  "machine_name": "memory_lifecycle_state_machine",
  "version": "1.4.0",
  "states": [
    "candidate",
    "draft",
    "validated",
    "active",
    "watchlist",
    "deprecated",
    "superseded",
    "archived"
  ],
  "requires_approval_for": [
    "validated_to_active",
    "active_to_deprecated",
    "active_to_superseded"
  ],
  "requires_transaction_for": [
    "validated_to_active",
    "active_to_deprecated",
    "active_to_superseded"
  ],
  "requires_audit_log_for": [
    "all_transitions"
  ]
}
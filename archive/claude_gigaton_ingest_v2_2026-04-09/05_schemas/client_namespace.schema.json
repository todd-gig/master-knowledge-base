{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gigaton Client Namespace",
  "type": "object",
  "required": [
    "namespace_id",
    "client_name",
    "parent_namespace",
    "industry",
    "goals",
    "constraints",
    "permissions"
  ],
  "properties": {
    "namespace_id": {
      "type": "string"
    },
    "client_name": {
      "type": "string"
    },
    "parent_namespace": {
      "type": "string"
    },
    "industry": {
      "type": "string"
    },
    "goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "permissions": {
      "type": "object"
    },
    "billing_profile": {
      "type": "object"
    },
    "source_links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
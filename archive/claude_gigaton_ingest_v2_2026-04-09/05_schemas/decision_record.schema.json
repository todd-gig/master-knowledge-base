{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decision Record",
  "type": "object",
  "required": [
    "decision_id",
    "objective",
    "options",
    "selected_option",
    "score",
    "approval_required",
    "status"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "selected_option": {
      "type": "string"
    },
    "score": {
      "type": "number"
    },
    "approval_required": {
      "type": "boolean"
    },
    "status": {
      "enum": [
        "proposed",
        "approved",
        "rejected",
        "implemented",
        "rolled_back"
      ]
    },
    "rationale": {
      "type": "string"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gigaton Task",
  "type": "object",
  "required": [
    "task_id",
    "title",
    "objective",
    "priority",
    "status",
    "owner_role",
    "acceptance_criteria"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "priority": {
      "type": "number"
    },
    "status": {
      "enum": [
        "backlog",
        "ready",
        "in_progress",
        "blocked",
        "review",
        "done"
      ]
    },
    "owner_role": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "roi_rationale": {
      "type": "string"
    }
  }
}
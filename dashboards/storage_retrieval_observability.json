{
  "displayName": "gigaton-storage-retrieval-observability",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "width": 12,
        "height": 1,
        "widget": {
          "title": "decision-engine — write/exec rates + calibration",
          "text": {
            "content": "decision_records write rate (proxy: /v1/decisions/process 2xx) • execution_records insert rate (proxy: /v1/executions/record 2xx) • calibration variance (manual probe /v1/penrose/scoreboard)",
            "format": "MARKDOWN"
          }
        }
      },
      {
        "yPos": 1,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "decision-engine — request rate by response code (decision-engine Cloud Run service)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"decision-engine\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_RATE",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": [
                        "metric.label.\"response_code_class\""
                      ]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "timeshiftDuration": "0s"
          }
        }
      },
      {
        "yPos": 1,
        "xPos": 6,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "decision-engine — p95 latency by route",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"decision-engine\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_95",
                      "crossSeriesReducer": "REDUCE_MEAN",
                      "groupByFields": [
                        "metric.label.\"route\""
                      ]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
